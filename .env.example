# Ghost v5.5 Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# === API Keys ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GHOST_MINIMAX_API_KEY=your_minimax_api_key_here
GHOST_DATABENTO_API_KEY=your_databento_api_key_here
GHOST_TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
GHOST_TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === Database ===
GHOST_DATABASE_URL=postgresql://ghost:ghost@localhost:5432/ghost
GHOST_REDIS_URL=redis://localhost:6379/0

# === LLM Configuration ===
GHOST_MINIMAX_MODEL=minimax-2.5
GHOST_QWEN_ENDPOINT=http://localhost:8081/v1

# === Risk (override defaults) ===
# GHOST_MAX_DAILY_LOSS_PCT=0.03
# GHOST_PAYOUT_TARGET_DOLLARS=3000.0
